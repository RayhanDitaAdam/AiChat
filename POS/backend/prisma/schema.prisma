generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Merged Enums ---
enum Role {
  USER
  STAFF
  OWNER
  ADMIN
}

// --- Shared Models (Extended) ---

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String?   @unique
  googleId      String?   @unique
  githubId      String?   @unique
  password      String?
  name          String?
  image         String?
  avatarVariant String?   @default("beam")
  role          Role      @default(USER)
  ownerId       String?   @unique
  language      String    @default("id")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Custom Metadata
  phone         String?
  dob           DateTime?
  points        Int       @default(0)
  printerIp     String?
  printerPort   Int?
  customerId    String?   @unique
  qrCode        String?
  loyaltyPoints Int       @default(0)
  memberOfId    String?
  position      String?
  latitude      Float?
  longitude     Float?
  disabledMenus String[]  @default([])
  medicalRecord String?   @db.Text
  isBlocked     Boolean   @default(false)
  registrationType String @default("USER")
  isEmailVerified Boolean @default(true)
  
  // Relations
  chats            ChatHistory[]
  rewardActivities RewardActivity[]
  ratings          Rating[]
  reminders        Reminder[]
  shoppingList     ShoppingList?
  memberOf         Owner?        @relation("StoreMembers", fields: [memberOfId], references: [id])
  owner            Owner?        @relation("OwnerToUser", fields: [ownerId], references: [id])
  assignedTasks    FacilityTask[] @relation("StaffTasks")
  
  // POS Specific Relations
  handledTransactions Transaction[]  @relation("CashierTransactions")
  myTransactions      Transaction[]  @relation("MemberTransactions")
  posPointHistory     PointHistory[]
  healthData          HealthData[]

  @@index([googleId])
  @@index([githubId])
  @@index([role])
  @@index([language])
}

model Owner {
  id              String           @id @default(uuid())
  ownerCode       String?          @unique
  name            String
  avatarVariant   String?          @default("beam")
  domain          String           @unique
  isApproved      Boolean          @default(false)
  
  chats           ChatHistory[]
  missingRequests MissingRequest[]
  config          OwnerConfig?
  products        Product[]
  ratings         Rating[]
  members         User[]           @relation("StoreMembers")
  user            User?            @relation("OwnerToUser")
  facilityTasks   FacilityTask[]
  latitude        Float?
  longitude       Float?
  address         String?
  postalCode      String?
  googleMapsUrl   String?
  jobVacancies    JobVacancy[]
  subLocations    SubLocation[]
}

model Product {
  id                String             @id @default(uuid())
  owner_id          String
  name              String
  price             Float
  stock             Int                @default(0)
  halal             Boolean            @default(true)
  aisle             String
  map_url           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          String             @default("General")
  description       String?
  image             String?
  rak               String
  videoUrl          String?
  ingredients       String?            @db.Text
  isFastMoving      Boolean            @default(false)
  isSecondHand      Boolean            @default(false)
  productType       String             @default("jual") 
  
  // POS Specific
  barcode           String?            @unique
  categoryId        String?
  posCategory       Category?          @relation(fields: [categoryId], references: [id])
  transactionItems  TransactionItem[]

  owner             Owner              @relation(fields: [owner_id], references: [id])
  shoppingListItems ShoppingListItem[]
}

// --- POS Specific Models ---

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Transaction {
  id            String   @id @default(uuid())
  total         Float
  discount      Float    @default(0)
  paymentMethod String   // CASH, QRIS, DEBIT, etc.
  memberId      String?  
  cashierId     String   
  createdAt     DateTime @default(now())

  member  User?             @relation("MemberTransactions", fields: [memberId], references: [id])
  cashier User              @relation("CashierTransactions", fields: [cashierId], references: [id])
  items   TransactionItem[]
}

model TransactionItem {
  id            String @id @default(uuid())
  transactionId String
  productId     String
  quantity      Int
  price         Float  

  transaction Transaction @relation(fields: [transactionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
}

model PointHistory {
  id          String   @id @default(uuid())
  memberId    String
  amount      Int
  type        String   // EARN, SPEND
  description String?
  createdAt   DateTime @default(now())

  member User @relation(fields: [memberId], references: [id])
}

model Reward {
  id             String  @id @default(uuid())
  name           String  @unique
  pointsRequired Int
  stock          Int     @default(0)
  image          String?
}

model HealthData {
  id         String   @id @default(uuid())
  memberId   String
  type       String   // MEDICAL_RECORD, FOOD_ADVICE
  content    String   @db.Text 
  imageUrl   String?  
  aiResponse String?  @db.Text
  createdAt  DateTime @default(now())

  member User @relation(fields: [memberId], references: [id])
}

model Setting {
  id             String @id @default("global")
  storeName      String @default("Heart POS")
  address        String?
  phone          String?
  pointMinSpend  Float  @default(50000)
  pointRatio     Int    @default(10000) 
  pointRedeemVal Int    @default(1000)  
}

model DiscountCode {
  id        String   @id @default(uuid())
  code      String   @unique
  amount    Float
  type      String   @default("FIXED") 
  expiry    DateTime
  usageCount Int     @default(0)
}

// --- AiChat Base Models (Remaining) ---

model SystemConfig {
  id                String   @id @default("global")
  aiSystemPrompt    String   @default("You are Heart, an AI shopping assistant.")
  updatedAt         DateTime @updatedAt
  chatRetentionDays Int      @default(7)
  geminiApiKey      String?
  dailyChatLimitUser  Int    @default(50)
  dailyChatLimitOwner Int    @default(100)
}

model OwnerConfig {
  id            String  @id @default(uuid())
  owner_id      String  @unique
  showInventory Boolean @default(true)
  showChat      Boolean @default(true)
  owner         Owner   @relation(fields: [owner_id], references: [id])
}

model ShoppingList {
  id        String             @id @default(uuid())
  user_id   String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [user_id], references: [id])
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id               String       @id @default(uuid())
  shopping_list_id String
  product_id       String
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())
  product          Product      @relation(fields: [product_id], references: [id])
  shoppingList     ShoppingList @relation(fields: [shopping_list_id], references: [id])
}

model ChatHistory {
  id         String       @id @default(uuid())
  user_id    String
  owner_id   String
  message    String
  role       String
  timestamp  DateTime     @default(now())
  status     String?      @default("GENERAL")
  latitude   Float?
  longitude  Float?
  session_id String?
  metadata   Json?
  owner      Owner        @relation(fields: [owner_id], references: [id])
  session    ChatSession? @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [user_id], references: [id])

  @@index([session_id])
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  ownerId   String
  title     String?       @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  chats     ChatHistory[]

  @@index([userId, ownerId])
}

model MissingRequest {
  id           String @id @default(uuid())
  owner_id     String
  product_name String
  count        Int    @default(1)
  owner        Owner  @relation(fields: [owner_id], references: [id])
}

model Rating {
  id       String  @id @default(uuid())
  user_id  String
  owner_id String
  score    Int
  feedback String?
  owner    Owner   @relation(fields: [owner_id], references: [id])
  user     User    @relation(fields: [user_id], references: [id])
}

model Reminder {
  id          String   @id @default(uuid())
  user_id     String
  product     String
  remind_date DateTime
  user        User     @relation(fields: [user_id], references: [id])
}

model FacilityTask {
  id           String   @id @default(uuid())
  ownerId      String
  assignedToId String?  
  location     String
  taskDetail   String   @db.Text
  report       String?  @db.Text
  status       String   @default("PENDING")
  taskDate     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  owner        Owner    @relation(fields: [ownerId], references: [id])
  assignedTo   User?    @relation("StaffTasks", fields: [assignedToId], references: [id])
  subLocation   SubLocation? @relation(fields: [subLocationId], references: [id])
  subLocationId String?
}

model JobVacancy {
  id          String   @id @default(uuid())
  ownerId     String
  companyName String
  address     String
  phone       String
  title       String
  detail      String   @db.Text
  salary      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       Owner    @relation(fields: [ownerId], references: [id])
}

model SubLocation {
  id           String         @id @default(uuid())
  ownerId      String
  name         String
  view360Url   String?
  createdAt    DateTime       @default(now())
  owner        Owner          @relation(fields: [ownerId], references: [id])
  tasks        FacilityTask[]
}

model RewardActivity {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  description String
  type        String   @default("EARN") 
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model UserPending {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  code      String   
  expiresAt DateTime
  metadata  Json?    
  createdAt DateTime @default(now())
}
