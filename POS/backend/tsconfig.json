{
    "compilerOptions": {
        "outDir": "./dist",
        "module": "NodeNext",
        "target": "ESNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "moduleDetection": "force"
    },
    "include": [
        "src",
        "prisma"
    ],
    "exclude": [
        "node_modules"
    ]
}