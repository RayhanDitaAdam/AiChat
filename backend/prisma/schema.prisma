generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  googleId      String?       @unique
  password      String?
  name          String?
  image         String?
  role          Role          @default(USER)
  ownerId       String?       @unique
  language      String        @default("id")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  printerIp     String?
  printerPort   Int?
  customerId    String?       @unique
  loyaltyPoints Int           @default(0)
  memberOfId    String?
  qrCode        String?
  phone         String?
  latitude      Float?
  longitude     Float?
  chats         ChatHistory[]
  ratings       Rating[]
  reminders     Reminder[]
  shoppingList  ShoppingList?
  memberOf      Owner?        @relation("StoreMembers", fields: [memberOfId], references: [id])
  owner         Owner?        @relation("OwnerToUser", fields: [ownerId], references: [id])

  @@index([googleId])
  @@index([role])
  @@index([language])
}

model Owner {
  id              String           @id @default(uuid())
  name            String
  domain          String           @unique
  isApproved      Boolean          @default(false)
  chats           ChatHistory[]
  missingRequests MissingRequest[]
  config          OwnerConfig?
  products        Product[]
  ratings         Rating[]
  members         User[]           @relation("StoreMembers")
  user            User?            @relation("OwnerToUser")
  latitude        Float?
  longitude       Float?
}

model SystemConfig {
  id                String   @id @default("global")
  aiSystemPrompt    String   @default("You are Heart, an AI shopping assistant.")
  updatedAt         DateTime @updatedAt
  chatRetentionDays Int      @default(7)
  geminiApiKey      String?
}

model OwnerConfig {
  id            String  @id @default(uuid())
  owner_id      String  @unique
  showInventory Boolean @default(true)
  showChat      Boolean @default(true)
  owner         Owner   @relation(fields: [owner_id], references: [id])
}

model Product {
  id                String             @id @default(uuid())
  owner_id          String
  name              String
  price             Float
  stock             Int                @default(0)
  halal             Boolean            @default(true)
  aisle             String
  map_url           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          String             @default("General")
  description       String?
  image             String?
  rak               String
  owner             Owner              @relation(fields: [owner_id], references: [id])
  shoppingListItems ShoppingListItem[]
}

model ShoppingList {
  id        String             @id @default(uuid())
  user_id   String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [user_id], references: [id])
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id               String       @id @default(uuid())
  shopping_list_id String
  product_id       String
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())
  product          Product      @relation(fields: [product_id], references: [id])
  shoppingList     ShoppingList @relation(fields: [shopping_list_id], references: [id])
}

model ChatHistory {
  id         String       @id @default(uuid())
  user_id    String
  owner_id   String
  message    String
  role       String
  timestamp  DateTime     @default(now())
  status     String?      @default("GENERAL")
  latitude   Float?
  longitude  Float?
  session_id String?
  metadata   Json?
  owner      Owner        @relation(fields: [owner_id], references: [id])
  session    ChatSession? @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [user_id], references: [id])

  @@index([session_id])
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  ownerId   String
  title     String?       @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  chats     ChatHistory[]

  @@index([userId, ownerId])
}

model MissingRequest {
  id           String @id @default(uuid())
  owner_id     String
  product_name String
  count        Int    @default(1)
  owner        Owner  @relation(fields: [owner_id], references: [id])
}

model Rating {
  id       String  @id @default(uuid())
  user_id  String
  owner_id String
  score    Int
  feedback String?
  owner    Owner   @relation(fields: [owner_id], references: [id])
  user     User    @relation(fields: [user_id], references: [id])
}

model Reminder {
  id          String   @id @default(uuid())
  user_id     String
  product     String
  remind_date DateTime
  user        User     @relation(fields: [user_id], references: [id])
}

enum Role {
  USER
  OWNER
  ADMIN
}
