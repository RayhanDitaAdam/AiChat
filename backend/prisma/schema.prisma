generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String               @id @default(uuid())
  email                    String               @unique
  googleId                 String?              @unique
  password                 String?
  name                     String?
  image                    String?
  role                     Role                 @default(USER)
  ownerId                  String?              @unique
  language                 String               @default("id")
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  printerIp                String?
  printerPort              Int?
  customerId               String?              @unique
  loyaltyPoints            Int                  @default(0)
  memberOfId               String?
  qrCode                   String?
  phone                    String?
  disabledMenus            String[]             @default([])
  githubId                 String?              @unique
  isBlocked                Boolean              @default(false)
  isEmailVerified          Boolean              @default(true)
  latitude                 Float?
  longitude                Float?
  medicalRecord            String?
  position                 String?
  staffRoleId              String?
  registrationType         String               @default("USER")
  avatarVariant            String?              @default("beam")
  dob                      DateTime?
  points                   Int                  @default(0)
  username                 String?              @unique
  loginAttempts            Int                  @default(0)
  loginLockedUntil         DateTime?
  resetPasswordAttempts    Int                  @default(0)
  resetPasswordExpires     DateTime?
  resetPasswordLockedUntil DateTime?
  resetPasswordToken       String?              @unique
  twoFactorCode            String?
  twoFactorCodeExpiry      DateTime?
  twoFactorEnabled         Boolean              @default(false)
  twoFactorRetryCount      Int                  @default(0)
  superAdminKeyHash        String?
  chats                    ChatHistory[]
  contributorRequests      ContributorRequest[]
  assignedTasks            FacilityTask[]       @relation("StaffTasks")
  healthData               HealthData[]
  posPointHistory          PointHistory[]
  contributedProducts      Product[]            @relation("ContributorProducts")
  ratings                  Rating[]
  reminders                Reminder[]
  rewardActivities         RewardActivity[]
  shoppingList             ShoppingList?
  handledTransactions      Transaction[]        @relation("CashierTransactions")
  myTransactions           Transaction[]        @relation("MemberTransactions")
  memberOf                 Owner?               @relation("StoreMembers", fields: [memberOfId], references: [id])
  owner                    Owner?               @relation("OwnerToUser", fields: [ownerId], references: [id])
  staffRole                StaffRole?           @relation(fields: [staffRoleId], references: [id])
  superAdminLogs           AuditLog[]           @relation("SuperAdminAuditLogs")
  targetAdminLogs          AuditLog[]           @relation("TargetAdminAuditLogs")
  staffActivities          StaffActivity[]      @relation("StaffActivities")
  ownerActivities          StaffActivity[]      @relation("OwnerActivities")

  @@index([googleId])
  @@index([githubId])
  @@index([role])
  @@index([language])
}

model Owner {
  id                  String               @id @default(uuid())
  name                String
  domain              String               @unique
  isApproved          Boolean              @default(false)
  address             String?
  googleMapsUrl       String?
  latitude            Float?
  longitude           Float?
  ownerCode           String?              @unique
  postalCode          String?
  avatarVariant       String?              @default("beam")
  businessCategory    String               @default("RETAIL")
  chats               ChatHistory[]
  contributorRequests ContributorRequest[]
  facilityTasks       FacilityTask[]
  jobVacancies        JobVacancy[]
  missingRequests     MissingRequest[]
  config              OwnerConfig?
  posRewards          POSReward[]
  posSetting          POSSetting?
  products            Product[]
  ratings             Rating[]
  reminders           Reminder[]
  staffRoles          StaffRole[]
  subLocations        SubLocation[]
  transactions        Transaction[]
  members             User[]               @relation("StoreMembers")
  user                User?                @relation("OwnerToUser")
}

model SystemConfig {
  id                  String   @id @default("global")
  aiSystemPrompt      String   @default("You are Heart, an AI shopping assistant.")
  updatedAt           DateTime @updatedAt
  chatRetentionDays   Int      @default(7)
  geminiApiKey        String?
  dailyChatLimitOwner Int      @default(100)
  dailyChatLimitUser  Int      @default(50)
  aiMaxTokens         Int      @default(1024)
  aiTemperature       Float    @default(0.7)
  aiTone              String   @default("HELPFUL")
  aiTopP              Float    @default(1.0)
}

model OwnerConfig {
  id             String  @id @default(uuid())
  owner_id       String  @unique
  showInventory  Boolean @default(true)
  showChat       Boolean @default(true)
  aiMaxTokens    Int     @default(1024)
  aiSystemPrompt String?
  aiTemperature  Float   @default(0.7)
  aiTone         String  @default("HELPFUL")
  aiTopK         Int     @default(40)
  aiTopP         Float   @default(1.0)
  owner          Owner   @relation(fields: [owner_id], references: [id])
}

model Product {
  id                String             @id @default(uuid())
  owner_id          String
  name              String
  price             Float
  stock             Int                @default(0)
  halal             Boolean            @default(true)
  aisle             String
  map_url           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          String             @default("General")
  description       String?
  image             String?
  rak               String
  bedType           String?
  ingredients       String?
  isFastMoving      Boolean            @default(false)
  isSecondHand      Boolean            @default(false)
  productType       String             @default("jual")
  room              String?
  section           String?
  videoUrl          String?
  view360Url        String?
  barcode           String?            @unique
  categoryId        String?
  expiryDate        DateTime?
  expiryNotified    Boolean            @default(false)
  warningNotified   Boolean            @default(false)
  contributorId     String?
  status            String             @default("APPROVED")
  posCategory       Category?          @relation(fields: [categoryId], references: [id])
  contributor       User?              @relation("ContributorProducts", fields: [contributorId], references: [id])
  owner             Owner              @relation(fields: [owner_id], references: [id])
  promos            ProductPromo[]
  shoppingListItems ShoppingListItem[]
  transactionItems  TransactionItem[]
}

model ShoppingList {
  id        String             @id @default(uuid())
  user_id   String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [user_id], references: [id])
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id               String       @id @default(uuid())
  shopping_list_id String
  product_id       String
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())
  product          Product      @relation(fields: [product_id], references: [id])
  shoppingList     ShoppingList @relation(fields: [shopping_list_id], references: [id])
}

model ChatHistory {
  id         String       @id @default(uuid())
  user_id    String?
  owner_id   String
  message    String
  role       String
  timestamp  DateTime     @default(now())
  status     String?      @default("GENERAL")
  latitude   Float?
  longitude  Float?
  session_id String?
  metadata   Json?
  owner      Owner        @relation(fields: [owner_id], references: [id])
  session    ChatSession? @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [user_id], references: [id])

  @@index([session_id])
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String?
  ownerId   String
  title     String?       @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  guestId   String?
  chats     ChatHistory[]

  @@index([userId, ownerId])
  @@index([guestId])
}

model Rating {
  id         String  @id @default(uuid())
  user_id    String?
  owner_id   String
  score      Int
  feedback   String?
  guest_id   String?
  session_id String?
  owner      Owner   @relation(fields: [owner_id], references: [id])
  user       User?   @relation(fields: [user_id], references: [id])
}

model FacilityTask {
  id            String       @id @default(uuid())
  ownerId       String
  assignedToId  String?
  location      String
  taskDetail    String
  report        String?
  status        String       @default("PENDING")
  taskDate      DateTime
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  subLocationId String?
  batchId       String?
  assignedTo    User?        @relation("StaffTasks", fields: [assignedToId], references: [id])
  owner         Owner        @relation(fields: [ownerId], references: [id])
  subLocation   SubLocation? @relation(fields: [subLocationId], references: [id])
}

model ProductPromo {
  id              String   @id @default(uuid())
  productId       String
  type            String
  promoPrice      Float?
  discountPercent Float?
  freeItemName    String?
  startDate       DateTime
  endDate         DateTime
  product         Product  @relation(fields: [productId], references: [id])
}

model JobVacancy {
  id          String   @id @default(uuid())
  ownerId     String
  companyName String
  address     String
  phone       String
  title       String
  detail      String
  salary      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       Owner    @relation(fields: [ownerId], references: [id])
}

model SubLocation {
  id         String         @id @default(uuid())
  ownerId    String
  name       String
  view360Url String?
  createdAt  DateTime       @default(now())
  tasks      FacilityTask[]
  owner      Owner          @relation(fields: [ownerId], references: [id])
}

model RewardActivity {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  description String
  type        String   @default("EARN")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model UserPending {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  code      String
  expiresAt DateTime
  metadata  Json?
  createdAt DateTime @default(now())
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Transaction {
  id            String            @id @default(uuid())
  total         Float
  discount      Float             @default(0)
  paymentMethod String
  memberId      String?
  cashierId     String
  createdAt     DateTime          @default(now())
  ownerId       String
  cashier       User              @relation("CashierTransactions", fields: [cashierId], references: [id])
  member        User?             @relation("MemberTransactions", fields: [memberId], references: [id])
  owner         Owner             @relation(fields: [ownerId], references: [id])
  items         TransactionItem[]
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String
  quantity      Int
  price         Float
  product       Product     @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model PointHistory {
  id          String    @id @default(uuid())
  memberId    String
  amount      Int
  type        String
  description String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  member      User      @relation(fields: [memberId], references: [id])
}

model POSReward {
  id             String  @id @default(uuid())
  name           String  @unique
  pointsRequired Int
  stock          Int     @default(0)
  image          String?
  ownerId        String
  owner          Owner   @relation(fields: [ownerId], references: [id])
}

model HealthData {
  id         String   @id @default(uuid())
  memberId   String
  type       String
  content    String
  imageUrl   String?
  aiResponse String?
  createdAt  DateTime @default(now())
  member     User     @relation(fields: [memberId], references: [id])
}

model POSSetting {
  id                     String  @id @default(uuid())
  storeName              String  @default("Heart POS")
  address                String?
  phone                  String?
  pointMinSpend          Float   @default(50000)
  pointRatio             Int     @default(10000)
  pointRedeemVal         Int     @default(1000)
  ownerId                String  @unique
  pointBonusBirthday     Int     @default(50)
  pointBonusRegistration Int     @default(10)
  pointExpiryDays        Int     @default(365)
  pointFridayMultiplier  Int     @default(2)
  pointMaxUsagePercent   Int     @default(50)
  pointMinRedeem         Int     @default(10)
  owner                  Owner   @relation(fields: [ownerId], references: [id])
}

model DiscountCode {
  id         String   @id @default(uuid())
  code       String   @unique
  amount     Float
  type       String   @default("FIXED")
  expiry     DateTime
  usageCount Int      @default(0)
}

model StaffRole {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  permissions Json?
  createdAt   DateTime @default(now())
  owner       Owner    @relation(fields: [ownerId], references: [id])
  users       User[]

  @@unique([ownerId, name])
}

model Reminder {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  ownerId   String
  remindAt  DateTime
  status    String   @default("PENDING")
  userId    String
  owner     Owner    @relation(fields: [ownerId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model MissingRequest {
  id        String   @id @default(uuid())
  count     Int      @default(1)
  createdAt DateTime @default(now())
  ownerId   String
  query     String
  status    String   @default("OPEN")
  updatedAt DateTime @updatedAt
  owner     Owner    @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, query])
}

model ContributorRequest {
  id        String   @id @default(uuid())
  userId    String
  ownerId   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     Owner    @relation(fields: [ownerId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, ownerId])
}

model AICache {
  id        String   @id @default(uuid())
  ownerId   String?
  query     String
  queryHash String
  response  String
  language  String   @default("id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, queryHash, language])
  @@index([queryHash])
}

enum Role {
  USER
  OWNER
  ADMIN
  STAFF
  CONTRIBUTOR
  SUPER_ADMIN
}

model AuditLog {
  id              String   @id @default(uuid())
  superAdminId    String
  targetAdminId   String?
  action          String
  ipAddress       String?
  details         Json?
  timestamp       DateTime @default(now())

  superAdmin      User     @relation("SuperAdminAuditLogs", fields: [superAdminId], references: [id])
  targetAdmin     User?    @relation("TargetAdminAuditLogs", fields: [targetAdminId], references: [id], onDelete: SetNull)

  @@index([superAdminId])
  @@index([action])
}

model StaffActivity {
  id          String   @id @default(uuid())
  staffId     String
  ownerId     String
  action      String
  description String?
  details     Json?
  createdAt   DateTime @default(now())

  staff       User     @relation("StaffActivities", fields: [staffId], references: [id], onDelete: Cascade)
  owner       User     @relation("OwnerActivities", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([ownerId])
  @@index([action])
}
