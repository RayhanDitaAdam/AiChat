generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  googleId      String?       @unique
  githubId      String?       @unique
  password      String?
  name          String?
  image         String?
  avatarVariant String?       @default("beam")
  role          Role          @default(USER)
  ownerId       String?       @unique
  language      String        @default("id")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  printerIp     String?
  printerPort   Int?
  customerId    String?       @unique
  loyaltyPoints Int           @default(0)
  memberOfId    String?
  qrCode        String?
  phone         String?
  position      String?       // For staff (e.g. "Cleaner", "Security")
  latitude      Float?
  longitude     Float?
  disabledMenus String[]      @default([])
  medicalRecord String?       @db.Text
  isBlocked        Boolean          @default(false)
  registrationType String           @default("USER") // USER, MEMBER
  isEmailVerified  Boolean          @default(true) // Verified users only in this table
  resetPasswordToken   String?       @unique
  resetPasswordExpires DateTime?
  resetPasswordAttempts Int          @default(0)
  resetPasswordLockedUntil DateTime?
  loginAttempts Int                  @default(0)
  loginLockedUntil DateTime?
  chats            ChatHistory[]
  rewardActivities RewardActivity[]
  ratings          Rating[]
  reminders     Reminder[]
  shoppingList  ShoppingList?
  memberOf      Owner?        @relation("StoreMembers", fields: [memberOfId], references: [id])
  owner         Owner?        @relation("OwnerToUser", fields: [ownerId], references: [id])
  assignedTasks FacilityTask[] @relation("StaffTasks")
  
  // POS Specific Relations
  username        String?       @unique
  dob             DateTime?
  points          Int           @default(0)
  handledTransactions Transaction[]  @relation("CashierTransactions")
  myTransactions      Transaction[]  @relation("MemberTransactions")
  posPointHistory     PointHistory[]
  healthData          HealthData[]
  twoFactorEnabled    Boolean          @default(false)
  twoFactorCode       String?
  twoFactorCodeExpiry DateTime?
  twoFactorRetryCount Int              @default(0)

  contributorRequests   ContributorRequest[]
  contributedProducts   Product[]        @relation("ContributorProducts")
  
  @@index([googleId])
  @@index([githubId])
  @@index([role])
  @@index([language])
}

model Owner {
  id              String           @id @default(uuid())
  ownerCode       String?          @unique
  name            String
  avatarVariant   String?          @default("beam")
  domain          String           @unique
  isApproved      Boolean          @default(false)
  chats           ChatHistory[]
  missingRequests MissingRequest[]
  config          OwnerConfig?
  products        Product[]
  ratings         Rating[]
  members         User[]           @relation("StoreMembers")
  user            User?            @relation("OwnerToUser")
  facilityTasks   FacilityTask[]
  latitude      Float?
  longitude     Float?
  address       String?
  postalCode    String?
  googleMapsUrl String?
  jobVacancies  JobVacancy[]
  subLocations  SubLocation[]
  transactions   Transaction[]
  posRewards     POSReward[]

  posSetting     POSSetting?
  staffRoles     StaffRole[]
  reminders      Reminder[]
  contributorRequests ContributorRequest[]
  businessCategory String @default("RETAIL") // RETAIL, HOTEL, SERVICE
}


model SystemConfig {
  id                String   @id @default("global")
  aiSystemPrompt    String   @default("You are Heart, an AI shopping assistant.")
  updatedAt         DateTime @updatedAt
  chatRetentionDays Int      @default(7)
  geminiApiKey      String?
  dailyChatLimitUser  Int    @default(50)
  dailyChatLimitOwner Int    @default(100)

  // Advanced AI Tuning (Global)
  aiTemperature Float   @default(0.7)
  aiTopP        Float   @default(1.0)
  aiMaxTokens   Int     @default(1024)
  aiTone        String  @default("HELPFUL") // HELPFUL, AGGRESSIVE, PROFESSIONAL, FRIENDLY
}

model OwnerConfig {
  id            String  @id @default(uuid())
  owner_id      String  @unique
  showInventory Boolean @default(true)
  showChat      Boolean @default(true)
  
  // Advanced AI Tuning
  aiTemperature Float   @default(0.7)
  aiTopP        Float   @default(1.0)
  aiTopK        Int     @default(40)
  aiMaxTokens   Int     @default(1024)
  aiSystemPrompt String? @db.Text
  aiTone        String  @default("HELPFUL") // HELPFUL, AGGRESSIVE, PROFESSIONAL, FRIENDLY
  
  owner         Owner   @relation(fields: [owner_id], references: [id])
}

model Product {
  id                String             @id @default(uuid())
  owner_id          String
  name              String
  price             Float
  stock             Int                @default(0)
  halal             Boolean            @default(true)
  aisle             String
  map_url           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          String             @default("General")
  description       String?
  image             String?
  rak               String
  videoUrl          String?
  ingredients       String?            @db.Text
  isFastMoving      Boolean            @default(false)
  isSecondHand      Boolean            @default(false)
  productType       String             @default("jual") // jual, sewa
  bedType           String?            // for hotel/rent room
  room              String?            // for building placement
  section           String?            // for aisle/section
  view360Url        String?
  expiryDate        DateTime?
  expiryNotified    Boolean            @default(false)
  warningNotified   Boolean            @default(false)
  promos            ProductPromo[]
  owner             Owner              @relation(fields: [owner_id], references: [id])
  shoppingListItems ShoppingListItem[]

  // POS Specific
  barcode           String?            @unique
  categoryId        String?
  posCategory       Category?          @relation(fields: [categoryId], references: [id])
  transactionItems  TransactionItem[]
  
  contributorId     String?
  status            String             @default("APPROVED") // APPROVED, PENDING, REJECTED
  contributor       User?              @relation("ContributorProducts", fields: [contributorId], references: [id])
}

model ShoppingList {
  id        String             @id @default(uuid())
  user_id   String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [user_id], references: [id])
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id               String       @id @default(uuid())
  shopping_list_id String
  product_id       String
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())
  product          Product      @relation(fields: [product_id], references: [id])
  shoppingList     ShoppingList @relation(fields: [shopping_list_id], references: [id])
}

model ChatHistory {
  id         String       @id @default(uuid())
  user_id    String?      // Made optional for Guest
  owner_id   String
  message    String
  role       String
  timestamp  DateTime     @default(now())
  status     String?      @default("GENERAL")
  latitude   Float?
  longitude  Float?
  session_id String?
  metadata   Json?
  owner      Owner        @relation(fields: [owner_id], references: [id])
  session    ChatSession? @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [user_id], references: [id]) // Made optional relation

  @@index([session_id])
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String?       // Made optional for Guest
  ownerId   String
  title     String?       @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  chats     ChatHistory[]
  guestId   String?       // New field to track guest via fingerprint/cookie if needed
  
  @@index([userId, ownerId])
  @@index([guestId])
}


model Rating {
  id        String   @id @default(uuid())
  user_id   String?
  guest_id  String?  // For unauthenticated users
  session_id String? // Track the specific session
  owner_id  String
  score     Int
  feedback  String?
  owner     Owner    @relation(fields: [owner_id], references: [id])
  user      User?    @relation(fields: [user_id], references: [id])
}


model FacilityTask {
  id           String   @id @default(uuid())
  ownerId      String
  assignedToId String?  // Optional assignment to a specific staff member
  location     String
  taskDetail   String   @db.Text
  report       String?  @db.Text
  status       String   @default("PENDING")
  taskDate     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  owner        Owner    @relation(fields: [ownerId], references: [id])
  assignedTo   User?    @relation("StaffTasks", fields: [assignedToId], references: [id])
  subLocation   SubLocation? @relation(fields: [subLocationId], references: [id])
  subLocationId String?
  batchId      String?  // UUID to group tasks assigned together (e.g. "All Staff")
}

enum Role {
  USER
  STAFF
  OWNER
  ADMIN
  CONTRIBUTOR
}

model ProductPromo {
  id              String   @id @default(uuid())
  productId       String
  type            String   // DISCOUNT, FREE
  promoPrice      Float?
  discountPercent Float?
  freeItemName    String?
  startDate       DateTime
  endDate         DateTime
  product         Product  @relation(fields: [productId], references: [id])
}

model JobVacancy {
  id          String   @id @default(uuid())
  ownerId     String
  companyName String
  address     String
  phone       String
  title       String
  detail      String   @db.Text
  salary      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       Owner    @relation(fields: [ownerId], references: [id])
}

model SubLocation {
  id           String         @id @default(uuid())
  ownerId      String
  name         String
  view360Url   String?
  createdAt    DateTime       @default(now())
  owner        Owner          @relation(fields: [ownerId], references: [id])
  tasks        FacilityTask[]
}

model RewardActivity {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  description String
  type        String   @default("EARN") // EARN, SPEND
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model UserPending {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  code      String   // OTP
  expiresAt DateTime
  metadata  Json?    // For Owner (storeName, domain) or other extra data
  createdAt DateTime @default(now())
}

// --- POS Specific Models ---

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Transaction {
  id            String   @id @default(uuid())
  ownerId       String
  total         Float
  discount      Float    @default(0)
  paymentMethod String   // CASH, QRIS, DEBIT, etc.
  memberId      String?  
  cashierId     String   
  createdAt     DateTime @default(now())

  owner   Owner             @relation(fields: [ownerId], references: [id])
  member  User?             @relation("MemberTransactions", fields: [memberId], references: [id])
  cashier User              @relation("CashierTransactions", fields: [cashierId], references: [id])
  items   TransactionItem[]
}

model TransactionItem {
  id            String @id @default(uuid())
  transactionId String
  productId     String
  quantity      Int
  price         Float  

  transaction Transaction @relation(fields: [transactionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
}

model PointHistory {
  id          String   @id @default(uuid())
  memberId    String
  amount      Int
  type        String   // EARN, SPEND
  description String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  member User @relation(fields: [memberId], references: [id])
}

model POSReward {
  id             String  @id @default(uuid())
  ownerId        String
  name           String  @unique
  pointsRequired Int
  stock          Int     @default(0)
  image          String?

  owner Owner @relation(fields: [ownerId], references: [id])
}

model HealthData {
  id         String   @id @default(uuid())
  memberId   String
  type       String   // MEDICAL_RECORD, FOOD_ADVICE
  content    String   @db.Text 
  imageUrl   String?  
  aiResponse String?  @db.Text
  createdAt  DateTime @default(now())

  member User @relation(fields: [memberId], references: [id])
}

model POSSetting {
  id             String  @id @default(uuid())
  ownerId        String  @unique
  storeName      String  @default("Heart POS")
  address        String?
  phone          String?
  pointMinSpend  Float   @default(50000)
  pointRatio     Int     @default(10000)
  pointRedeemVal Int     @default(1000)
  
  // Enhanced Point Rules
  pointExpiryDays       Int @default(365)
  pointMaxUsagePercent  Int @default(50)
  pointMinRedeem        Int @default(10)
  pointBonusRegistration Int @default(10)
  pointBonusBirthday    Int @default(50)
  pointFridayMultiplier Int @default(2)

  owner Owner @relation(fields: [ownerId], references: [id])
}

model DiscountCode {
  id        String   @id @default(uuid())
  code      String   @unique
  amount    Float
  type      String   @default("FIXED") 
  expiry    DateTime
  usageCount Int     @default(0)
}

model StaffRole {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())

  owner Owner @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, name])
}

model Reminder {
  id        String   @id @default(uuid())
  userId    String
  ownerId   String
  content   String   @db.Text
  remindAt  DateTime
  status    String   @default("PENDING") // PENDING, COMPLETED
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  owner Owner @relation(fields: [ownerId], references: [id])
}
model MissingRequest {
  id        String   @id @default(uuid())
  ownerId   String
  query     String   // What they searched for
  count     Int      @default(1)
  status    String   @default("OPEN") // OPEN, REVIEWED, RESOLVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner Owner @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, query])
}

model ContributorRequest {
  id        String   @id @default(uuid())
  userId    String
  ownerId   String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id])
  owner     Owner    @relation(fields: [ownerId], references: [id])

  @@unique([userId, ownerId])
}

model AICache {
  id        String   @id @default(uuid())
  ownerId   String?
  query     String   @db.Text
  queryHash String
  response  String   @db.Text
  language  String   @default("id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, queryHash, language])
  @@index([queryHash])
}
