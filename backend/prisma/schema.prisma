generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  googleId      String?       @unique
  githubId      String?       @unique
  password      String?
  name          String?
  image         String?
  avatarVariant String?       @default("beam")
  role          Role          @default(USER)
  ownerId       String?       @unique
  language      String        @default("id")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  printerIp     String?
  printerPort   Int?
  customerId    String?       @unique
  loyaltyPoints Int           @default(0)
  memberOfId    String?
  qrCode        String?
  phone         String?
  position      String?       // For staff (e.g. "Cleaner", "Security")
  latitude      Float?
  longitude     Float?
  disabledMenus String[]      @default([])
  medicalRecord String?       @db.Text
  isBlocked        Boolean          @default(false)
  registrationType String           @default("USER") // USER, MEMBER
  isEmailVerified  Boolean          @default(true) // Verified users only in this table
  chats            ChatHistory[]
  rewardActivities RewardActivity[]
  ratings          Rating[]
  reminders     Reminder[]
  shoppingList  ShoppingList?
  memberOf      Owner?        @relation("StoreMembers", fields: [memberOfId], references: [id])
  owner         Owner?        @relation("OwnerToUser", fields: [ownerId], references: [id])
  assignedTasks FacilityTask[] @relation("StaffTasks")

  @@index([googleId])
  @@index([githubId])
  @@index([role])
  @@index([language])
}

model Owner {
  id              String           @id @default(uuid())
  ownerCode       String?          @unique
  name            String
  avatarVariant   String?          @default("beam")
  domain          String           @unique
  isApproved      Boolean          @default(false)
  chats           ChatHistory[]
  missingRequests MissingRequest[]
  config          OwnerConfig?
  products        Product[]
  ratings         Rating[]
  members         User[]           @relation("StoreMembers")
  user            User?            @relation("OwnerToUser")
  facilityTasks   FacilityTask[]
  latitude      Float?
  longitude     Float?
  address       String?
  postalCode    String?
  googleMapsUrl String?
  jobVacancies  JobVacancy[]
  subLocations  SubLocation[]
}

model SystemConfig {
  id                String   @id @default("global")
  aiSystemPrompt    String   @default("You are Heart, an AI shopping assistant.")
  updatedAt         DateTime @updatedAt
  chatRetentionDays Int      @default(7)
  geminiApiKey      String?
  dailyChatLimitUser  Int    @default(50)
  dailyChatLimitOwner Int    @default(100)
}

model OwnerConfig {
  id            String  @id @default(uuid())
  owner_id      String  @unique
  showInventory Boolean @default(true)
  showChat      Boolean @default(true)
  owner         Owner   @relation(fields: [owner_id], references: [id])
}

model Product {
  id                String             @id @default(uuid())
  owner_id          String
  name              String
  price             Float
  stock             Int                @default(0)
  halal             Boolean            @default(true)
  aisle             String
  map_url           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          String             @default("General")
  description       String?
  image             String?
  rak               String
  videoUrl          String?
  ingredients       String?            @db.Text
  isFastMoving      Boolean            @default(false)
  isSecondHand      Boolean            @default(false)
  productType       String             @default("jual") // jual, sewa
  bedType           String?            // for hotel/rent room
  room              String?            // for building placement
  section           String?            // for aisle/section
  view360Url        String?
  promos            ProductPromo[]
  owner             Owner              @relation(fields: [owner_id], references: [id])
  shoppingListItems ShoppingListItem[]
}

model ShoppingList {
  id        String             @id @default(uuid())
  user_id   String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [user_id], references: [id])
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id               String       @id @default(uuid())
  shopping_list_id String
  product_id       String
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())
  product          Product      @relation(fields: [product_id], references: [id])
  shoppingList     ShoppingList @relation(fields: [shopping_list_id], references: [id])
}

model ChatHistory {
  id         String       @id @default(uuid())
  user_id    String
  owner_id   String
  message    String
  role       String
  timestamp  DateTime     @default(now())
  status     String?      @default("GENERAL")
  latitude   Float?
  longitude  Float?
  session_id String?
  metadata   Json?
  owner      Owner        @relation(fields: [owner_id], references: [id])
  session    ChatSession? @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [user_id], references: [id])

  @@index([session_id])
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  ownerId   String
  title     String?       @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  chats     ChatHistory[]

  @@index([userId, ownerId])
}

model MissingRequest {
  id           String @id @default(uuid())
  owner_id     String
  product_name String
  count        Int    @default(1)
  owner        Owner  @relation(fields: [owner_id], references: [id])
}

model Rating {
  id       String  @id @default(uuid())
  user_id  String
  owner_id String
  score    Int
  feedback String?
  owner    Owner   @relation(fields: [owner_id], references: [id])
  user     User    @relation(fields: [user_id], references: [id])
}

model Reminder {
  id          String   @id @default(uuid())
  user_id     String
  product     String
  remind_date DateTime
  user        User     @relation(fields: [user_id], references: [id])
}

model FacilityTask {
  id           String   @id @default(uuid())
  ownerId      String
  assignedToId String?  // Optional assignment to a specific staff member
  location     String
  taskDetail   String   @db.Text
  report       String?  @db.Text
  status       String   @default("PENDING")
  taskDate     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  owner        Owner    @relation(fields: [ownerId], references: [id])
  assignedTo   User?    @relation("StaffTasks", fields: [assignedToId], references: [id])
  subLocation   SubLocation? @relation(fields: [subLocationId], references: [id])
  subLocationId String?
}

enum Role {
  USER
  STAFF
  OWNER
  ADMIN
}

model ProductPromo {
  id              String   @id @default(uuid())
  productId       String
  type            String   // DISCOUNT, FREE
  promoPrice      Float?
  discountPercent Float?
  freeItemName    String?
  startDate       DateTime
  endDate         DateTime
  product         Product  @relation(fields: [productId], references: [id])
}

model JobVacancy {
  id          String   @id @default(uuid())
  ownerId     String
  companyName String
  address     String
  phone       String
  title       String
  detail      String   @db.Text
  salary      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       Owner    @relation(fields: [ownerId], references: [id])
}

model SubLocation {
  id           String         @id @default(uuid())
  ownerId      String
  name         String
  view360Url   String?
  createdAt    DateTime       @default(now())
  owner        Owner          @relation(fields: [ownerId], references: [id])
  tasks        FacilityTask[]
}

model RewardActivity {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  description String
  type        String   @default("EARN") // EARN, SPEND
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model UserPending {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  code      String   // OTP
  expiresAt DateTime
  metadata  Json?    // For Owner (storeName, domain) or other extra data
  createdAt DateTime @default(now())
}
