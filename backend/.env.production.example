# =============================================================================
# AiChat — Production Environment Variables (.env.production.example)
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to: backend/.env
#   2. Fill in ALL values marked with <CHANGEME>
#   3. Never commit .env to git!
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>?schema=public"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL="https://YOUR_DOMAIN"

# ── Security (Generate Strong Secrets!) ──────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="<CHANGEME_use_64char_random_string>"
CSRF_SECRET="<CHANGEME_use_64char_random_string>"
JWT_REFRESH_SECRET="<CHANGEME_use_64char_random_string>"

# ── AI / LLM ─────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY="<CHANGEME>"
GOOGLE_GEMINI_API_KEY="<CHANGEME>"

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="<CHANGEME>.apps.googleusercontent.com"

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID="<CHANGEME>"
GITHUB_CLIENT_SECRET="<CHANGEME>"
GITHUB_CALLBACK_URL="https://YOUR_DOMAIN/api/auth/github/callback"

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Create App Password: https://myaccount.google.com/apppasswords
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="<GMAIL_APP_PASSWORD>"

# ── ChromaDB (Vector DB for AI Knowledge) ───────────────────────────────────
CHROMA_URL="http://localhost:8000"

# ── Redis (Optional: for session/cache) ──────────────────────────────────────
# REDIS_URL="redis://localhost:6379"
